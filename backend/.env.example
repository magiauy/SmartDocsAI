DJANGO_SETTINGS_MODULE=app.settings.local
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

DB_USE_DOCKER=1
DB_ENGINE=django.db.backends.mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=smartdocsai
DB_USER=smartdocs
DB_PASSWORD=smartdocs

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=smartdocsai_documents
RETRIEVAL_TOP_K=5
CHUNK_SIZE=700
CHUNK_OVERLAP=120

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL_NAME=gemini-embedding-2-preview
EMBEDDING_VECTOR_SIZE=3072
EMBEDDING_DEVICE=cpu
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_GEMINI_TASK_TYPE_DOCUMENT=RETRIEVAL_DOCUMENT
EMBEDDING_GEMINI_TASK_TYPE_QUERY=RETRIEVAL_QUERY
EMBEDDING_STRICT=0

PADDLEOCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_TIMEOUT_SECONDS=60
PADDLEOCR_API_KEY=
PADDLEOCR_API_KEY_HEADER=Authorization
PADDLEOCR_API_KEY_PREFIX=bearer
PADDLEOCR_REQUEST_MODE=aistudio-job
PADDLEOCR_FILE_FIELD=file
PADDLEOCR_EXTRA_PARAMS_JSON={}
PADDLEOCR_MODEL=PaddleOCR-VL-1.5
PADDLEOCR_OPTIONAL_PAYLOAD_JSON={"useDocOrientationClassify":false,"useDocUnwarping":false,"useChartRecognition":false}
PADDLEOCR_JOB_POLL_SECONDS=5
PADDLEOCR_JOB_TIMEOUT_SECONDS=300

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2:1.5b

SESSION_MEMORY_ENABLED=1
SESSION_MEMORY_MAX_TURNS=8

MEDIA_ROOT=media
MEDIA_URL=/media/
